{
  "manifest_version": 3,
  "name": "TabNap — Suspend Inactive Tabs",
  "short_name": "TabNap",
  "description": "Auto-suspend inactive tabs to free RAM and speed up Chrome. One click to nap all tabs or wake them up.",
  "version": "1.0.0",
  "author": "Abhishek Rana",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["tabs", "storage", "alarms"],
  "background": { "service_worker": "src/background.js", "type": "module" },
  "action": { "default_popup": "src/popup/popup.html", "default_title": "TabNap" }
}
